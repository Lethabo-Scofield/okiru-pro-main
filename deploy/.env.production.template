# ══════════════════════════════════════════════════════════════════════════
#  Okiru Pro — Production Environment Template
#
#  Copy this file to `.env` (or load each value into your secret store such
#  as Azure Key Vault) and fill in real values. NEVER commit a populated
#  copy to git.
#
#  Audience: ops engineers running the AKS deployment in
#  kubernetes/infrastructure/overlays/prod. The same key names are wired
#  into the K8s Secret manifests in that overlay.
# ══════════════════════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=warn

# Public URLs (used to build invite links, OAuth redirects, etc.)
APP_BASE_URL=https://app.okiru.co.za
PUBLIC_URL=https://app.okiru.co.za
DOMAIN=app.okiru.co.za

# Comma-separated allowed origins for CORS on the API server.
CORS_ORIGIN=https://app.okiru.co.za

# ── MongoDB (primary user/auth + sessions) ───────────────────────────────
# Use Azure Cosmos DB for MongoDB API or a self-hosted Mongo replica set.
MONGO_INITDB_ROOT_USERNAME=okiru
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_strong_password
MONGODB_URI=mongodb+srv://okiru:<password>@<host>/okiru?retryWrites=true&w=majority
MONGODB_DB_NAME=okiru

# ── ArangoDB (B-BBEE knowledge graph) ────────────────────────────────────
ARANGO_URL=https://arango.internal:8529
ARANGO_DB_NAME=bbbee_db
ARANGO_USER=root
ARANGO_ROOT_PASSWORD=CHANGE_ME_strong_password
ARANGO_VERIFY_SSL=true

# ── Redis (Computation Engine cache / queue) ─────────────────────────────
REDIS_URL=redis://:<password>@redis.internal:6379/0
REDIS_PASSWORD=CHANGE_ME_strong_password

# ── Sessions / Auth ──────────────────────────────────────────────────────
# REQUIRED in production. Must be >= 32 random characters and must NOT look
# like a dev/test placeholder (env validation in apps/api/src/env.ts will
# refuse to boot otherwise). Generate with: openssl rand -hex 48
SESSION_SECRET=CHANGE_ME_64_random_chars
JWT_SECRET=CHANGE_ME_64_random_chars
# Shared secret for service-to-service calls between web → api → compute.
API_INTERNAL_KEY=CHANGE_ME_random

# ── SMTP (OTP email + workspace invite emails) ───────────────────────────
# Without these, OTP/invite emails are silently skipped — user accounts can
# still be created but won't be able to verify their email and therefore
# won't be able to accept workspace invites. Use Azure Communication
# Services Email, SendGrid, Mailgun, AWS SES, or any SMTP relay.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey-or-username
SMTP_PASS=CHANGE_ME
SMTP_FROM="Okiru Pro <no-reply@okiru.co.za>"
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
MAX_OTP_ATTEMPTS=5

# ── Azure OpenAI (used by api/extraction + Computation Engine) ───────────
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_API_KEY=CHANGE_ME
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Azure Blob Storage (certificate uploads from /apps/api) ──────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=okiruprod
AZURE_STORAGE_ACCOUNT=okiruprod   # alias for backup-sync sidecar
AZURE_STORAGE_KEY=CHANGE_ME

# ── Azure AI Search (certificate ingestion + retrieval) ──────────────────
AZURE_SEARCH_ENDPOINT=https://<service>.search.windows.net
AZURE_SEARCH_API_KEY=CHANGE_ME
AZURE_SEARCH_INDEX_NAME=okiru-certificates

# ── Optional LLM fallback (Groq for fast inference) ──────────────────────
GROQ_API_KEY=

# ── Organization subscription IDs (server-side validation) ───────────────
OKIRU_SUB_ID=OKR-2026-001
PARAM_SUB_ID=PRM-2026-001

# ── Inter-service URLs (set automatically inside K8s by the configmap) ───
# Override here only when running outside of the cluster (e.g. on a VM).
# COMPUTE_ENGINE_URL=http://compute:8000
# API_SERVER_URL=http://api:5000
