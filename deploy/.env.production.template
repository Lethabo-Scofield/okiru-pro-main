# ─── Okiru Production Environment ─────────────────────────────
# Copy this file to .env in the project root before running docker-compose

# MongoDB
MONGO_USER=okiru
MONGO_PASSWORD=CHANGE_ME_strong_password_here

# ArangoDB
ARANGO_PASSWORD=CHANGE_ME_strong_password_here
ARANGO_DB=bbbee_db

# API
SESSION_SECRET=CHANGE_ME_random_64_char_string
CORS_ORIGIN=http://YOUR_VM_IP,https://okiru.yourdomain.com

# Web (optional overrides)
# MONGODB_URI is auto-composed from MONGO_USER/MONGO_PASSWORD above

# Domain (update after DNS setup)
# DOMAIN=okiru.yourdomain.com
