{
  "name": "@okiru/logger",
  "version": "1.0.0",
  "description": "Structured, request-context-aware logger shared by all Okiru Node.js services. Pretty output in dev, JSON in production.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "CHANGELOG.md",
    "OWNERS.md",
    "catalog.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "echo 'No linting configured'",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet'"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
