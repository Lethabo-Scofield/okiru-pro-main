{
  "name": "@okiru/_template",
  "version": "0.0.0",
  "private": true,
  "description": "Standard scaffold for new @okiru shared TypeScript packages. Copy this folder, rename, and update OWNERS.md + catalog.json.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "CHANGELOG.md",
    "OWNERS.md",
    "catalog.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "echo 'No linting configured for template'",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests in template'"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "okiru": {
    "isTemplate": true
  }
}
