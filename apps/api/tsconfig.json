{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "rootDir": "../..",
    "baseUrl": ".",
    "paths": {
      "@okiru/data-layer": ["../../packages/data-layer/src/index.ts"]
    },
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../../packages/data-layer/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "vite.ts", "**/__tests__/**"]
}
